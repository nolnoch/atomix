# (orbits: int <= 8) Number of wave-circle orbits [default = 4]
orbits: 2

# (amplitude: float) Vertical displacement of waves [default = 0.6]
amplitude: 0.7

# (period: float) Wave period [default = 1.0]
period: 1.0

# (wavelength: double) Wavelength/lambda in multiples of pi [default = 2.0]
wavelength: 2.0

# (resolution: int) Render resolution of the circle (vertices per circumference) [default = 360]
resolution: 500

# (superposition: bool) Whether to respect superposition in co-planar wavefunctions [default = false]
superposition: true

# (shader: string) Vertex shader file name for this render [default = "ortho_wave.vert"]
shader: para_wave.vert
